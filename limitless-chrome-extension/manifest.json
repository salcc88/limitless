{
  "manifest_version": 3,
  "name": "Limitless",
  "short_name": "Limitless",
  "description": "Create website limits, set a schedule, and use Peek Mode to effectively manage distractions.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "alarms",
    "notifications"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": { "48": "assets/icons/icon48.png" },
    "default_title": "Limitless"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "web_accessible_resources": [{
    "resources": ["assets/font/plus-jakarta-sans-500.woff2"],
    "matches": ["<all_urls>"]
  }],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "content-scripts/check-engagement.js", 
        "content-scripts/timer.js"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "options_ui": {
    "page": "dashboard/index.html",
    "open_in_tab": true
  }
}
