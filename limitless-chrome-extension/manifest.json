{
  "manifest_version": 3,
  "name": "Limitless - Schedule Website Time Limits",
  "short_name": "Limitless",
  "description": "Stay focused and take control of your time. Create website limits, set a schedule, and utilize Peek Mode to effectively manage distractions.",
  "version": "1.0",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": { "48": "assets/icons/icon48.png" },
    "default_title": "Limitless"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["visibility-check.js", "timer.js"],
      "css": ["timer.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "options_ui": {
    "page": "dashboard/index.html",
    "open_in_tab": true
  }
}
